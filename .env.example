# Exemplo de variáveis de ambiente. Copie para .env e ajuste conforme necessário.
# Em docker-compose os valores já são injetados; este arquivo serve para
# execução dos serviços fora de contêiner.

# decisions-service
DATABASE_URL=postgresql+psycopg://decisor:decisor@localhost:5432/decisions
CATALOG_URL=http://localhost:8001
AMQP_URL=amqp://guest:guest@localhost:5672/

# api-gateway
DECISIONS_URL=http://localhost:8002
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_PER_MINUTE=120
